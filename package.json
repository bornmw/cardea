{
    "name": "cardea",
    "version": "1.0.0",
    "description": "Lightweight, zero-dependency Proof-of-Work anti-spam protection for WordPress comments",
    "main": "assets/js/frontend.js",
    "scripts": {
        "test:jest": "jest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test": "npm run test:jest && npm run test:e2e",
        "lint": "eslint assets/js/",
        "lint:fix": "eslint assets/js/ --fix"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.23.0",
        "@playwright/test": "^1.40.0",
        "@wp-playground/cli": "^3.0.0",
        "babel-jest": "^29.7.0",
        "eslint": "^8.52.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0"
    },
    "eslintConfig": {
        "env": {
            "browser": true,
            "es2021": true,
            "worker": true
        },
        "extends": "eslint:recommended",
        "parserOptions": {
            "ecmaVersion": "latest",
            "sourceType": "module"
        },
        "rules": {}
    },
    "jest": {
        "testEnvironment": "jsdom",
        "testMatch": ["**/tests/js/**/*.test.js"],
        "transform": {
            "^.+\\.js$": "babel-jest"
        },
        "moduleFileExtensions": ["js"]
    },
    "babel": {
        "presets": ["@babel/preset-env"]
    },
    "keywords": [
        "wordpress",
        "spam",
        "comments",
        "proof-of-work",
        "anti-spam"
    ],
    "author": "Your Name",
    "license": "GPL-2.0-or-later"
}
